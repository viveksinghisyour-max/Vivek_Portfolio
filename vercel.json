{
  "version": 2,
  "routes": [
    {
      "src": "/(.*\\.(css|js|jpg|png|svg|ico|webmanifest))",
      "dest": "/$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/images/(.*)",
      "dest": "/images/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
